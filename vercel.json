{
  "framework": null,
  "buildCommand": "",
  "installCommand": "",
  "outputDirectory": "apps/web/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://bloomberpl-da6e13c64b4e.herokuapp.com/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET,POST,OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type,Authorization,X-API-Key,X-Request-ID" }
      ]
    }
  ]
}
