# ============================================================
# GPW Bloomberg – Environment Variables
# ============================================================
# Copy this file to .env and fill in your keys.

# EODHD API key (https://eodhd.com/)
# Free demo: 'demo' (20 calls/day)
# Paid: $20/mo+ for unlimited EOD data
EODHD_API_KEY=demo

# EODHD mode: 'indices_only' (default) or 'all'
# indices_only = use EODHD only for WIG/WIG20/MWIG40/SWIG80 (saves calls)
# all          = use EODHD for every GPW ticker (needs paid plan)
EODHD_MODE=indices_only

# Max EODHD API calls per day (free plan = 20)
EODHD_MAX_DAILY_REQUESTS=20

# Global daily HTTP limit across ALL providers (safety net)
GLOBAL_DAILY_HTTP_LIMIT=500

# Admin API key — required for costly POST endpoints (pipeline, train, ingest, etc.)
# Generate a strong random key, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=

# Allowed CORS origins (comma-separated). Leave empty to allow all (dev mode).
# Example: https://your-app.vercel.app,http://localhost:3001
CORS_ORIGINS=

# Server port (default: 3001)
# PORT=3001
